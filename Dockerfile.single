# Control: install deps and build in same RUN (single layer for node_modules + source)
ARG BUN_VERSION=1.3

FROM oven/bun:${BUN_VERSION} AS build
WORKDIR /app
COPY . .
RUN bun install --frozen-lockfile 2>/dev/null || bun install && bun run build

COPY check-hashes.sh .
RUN bash check-hashes.sh .output || true

FROM oven/bun:${BUN_VERSION}-slim
WORKDIR /app
COPY --from=build /app/.output .output
EXPOSE 3000
CMD ["bun", ".output/server/index.mjs"]
